---
interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props as Props;
const isHome = currentPath === "/";
---

<header class="sticky top-0 z-40 border-b border-stone-200 bg-stone-50 shadow-[0_2px_10px_rgba(15,23,42,0.05)]">
  <div class="mx-auto flex h-24 w-[min(1160px,92%)] items-center justify-between gap-3 md:h-28">
    <a href="/" class="flex items-center gap-2 md:gap-3">
      <span class="grid h-20 w-20 place-items-center overflow-hidden md:h-24 md:w-24">
        <img src="/maasmagic_logo.png" alt="Maa's Magic logo" class="h-full w-full object-contain" loading="eager" />
      </span>
      <span class="leading-tight">
        <span class="block font-display text-2xl font-bold text-slate-900 md:text-3xl">Maa's Magic</span>
        <span class="block pt-1 text-[11px] font-extrabold uppercase tracking-[0.25em] text-brand-600 md:text-xs">Pickle Solution</span>
      </span>
    </a>

    <nav class="hidden items-center gap-6 text-sm font-semibold text-slate-600 md:flex" aria-label="Primary navigation">
      <a href="/#menu" class="hover:text-slate-900">Products</a>
      <a href="/#about" class="hover:text-slate-900">About</a>
      <a href="/#order" class="hover:text-slate-900">How to Order</a>
    </nav>

    <div class="flex items-center gap-2 md:hidden">
      <button id="mobile-cart-toggle" class="inline-flex items-center justify-center rounded-lg border border-stone-300 bg-white p-2 text-slate-700" aria-label="Open cart" data-open-cart>
        <i class="fa-solid fa-cart-shopping"></i>
      </button>
      <button id="menu-toggle" class="inline-flex items-center justify-center rounded-lg border border-stone-300 bg-white p-2 text-slate-700" aria-controls="mobile-menu" aria-expanded="false" aria-label="Open menu">
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>

    <div class="hidden items-center gap-2 md:flex">
      <a href="/#contact" class="inline-flex items-center gap-2 rounded-xl bg-brand-500 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-brand-600">
        <i class="fa-solid fa-headset"></i>
        Contact Us
      </a>
      <button class="inline-flex items-center gap-2 rounded-lg border border-stone-300 bg-white px-3 py-2 text-slate-700 hover:bg-stone-100" data-open-cart>
        <i class="fa-solid fa-cart-shopping"></i>
        <span>Cart</span>
        <span class="inline-grid h-5 min-w-5 place-items-center rounded-full bg-slate-900 px-1 text-[11px] text-white" data-cart-count>0</span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-stone-200 bg-stone-50 md:hidden">
    <nav class="mx-auto flex w-[min(1160px,92%)] flex-col gap-1 py-3 text-sm font-semibold text-slate-700" aria-label="Mobile navigation">
      <a href="/#menu" class="rounded-md px-2 py-2 hover:bg-brand-50">Products</a>
      <a href="/#about" class="rounded-md px-2 py-2 hover:bg-brand-50">About</a>
      <a href="/#order" class="rounded-md px-2 py-2 hover:bg-brand-50">How to Order</a>
      <a href="/#contact" class="mt-2 inline-flex items-center justify-center gap-2 rounded-lg bg-brand-500 px-4 py-2 font-bold text-white">
        <i class="fa-solid fa-headset"></i>
        Contact Us
      </a>
    </nav>
  </div>
</header>
