---
import type { Product } from "../data/products";
import { getProductImageBySlug } from "../data/products";

interface Props {
  product: Product;
}

const { product } = Astro.props as Props;
const minPrice = Math.min(...product.variants.map((variant) => variant.price));
const maxPrice = Math.max(...product.variants.map((variant) => variant.price));
const hasMultipleVariants = product.variants.length > 1;
const variantInputId = `card-variant-${product.slug}`;
const productImage = `${import.meta.env.BASE_URL}${getProductImageBySlug(product.slug)}`;
---

<article class="relative rounded-xl border border-stone-200 bg-white p-4 shadow-sm" data-product-card>
  <span class="absolute left-4 top-4 rounded-full bg-emerald-100/90 px-3 py-1 text-[11px] font-extrabold tracking-wide text-emerald-800">Available</span>
  <a href={`${import.meta.env.BASE_URL}products/${product.slug}/`} class="block">
    <img class="mb-4 mt-8 h-64 w-full rounded-lg border border-stone-200 bg-white object-contain p-2" src={productImage} alt={`${product.name} pickle image`} loading="lazy" />
  </a>
  <div class="flex items-start justify-between gap-3">
    <div>
      <a href={`${import.meta.env.BASE_URL}products/${product.slug}/`} class="text-lg font-bold text-slate-900 hover:text-brand-600">{product.name}</a>
      <p class="text-sm font-semibold text-slate-500">{product.malayalam}</p>
      <p class="mt-1 text-xs text-slate-500">{product.tagline}</p>
    </div>
    <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-700">
      {hasMultipleVariants ? `₹${minPrice} - ₹${maxPrice}` : `₹${minPrice}`}
    </span>
  </div>
  <p class="mt-2 text-sm text-slate-600">{product.shortDescription}</p>
  <p class="mt-2 text-xs text-slate-500"><span class="font-semibold">Expiry:</span> {product.shelfLife}</p>

  <label class="mt-3 block text-xs font-semibold text-slate-600">
    Weight
    <select id={variantInputId} class="mt-1 w-full rounded-lg border border-stone-300 bg-white px-2 py-1.5 text-xs text-slate-700" data-variant-select>
      {product.variants.map((variant) => (
        <option value={`${variant.weight}|${variant.price}`}>{variant.weight} - ₹{variant.price}</option>
      ))}
    </select>
  </label>

  <div class="mt-4 flex gap-2">
    <a href={`${import.meta.env.BASE_URL}products/${product.slug}/`} class="inline-flex items-center justify-center rounded-lg border border-stone-300 bg-white px-3 py-2 text-xs font-bold text-slate-700 hover:bg-stone-100">View Details</a>
    <button
      class="inline-flex items-center justify-center gap-2 rounded-lg bg-slate-900 px-3 py-2 text-xs font-bold text-white hover:bg-slate-800"
      data-add-to-cart
      data-product-slug={product.slug}
      data-product-name={product.name}
      data-product-image={productImage}
      data-variant-input={variantInputId}
    >
      <i class="fa-solid fa-cart-plus"></i>
      Add to Cart
    </button>
  </div>
</article>
