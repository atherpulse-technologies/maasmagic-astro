---
const year = new Date().getFullYear();
import { companyContact } from "../config/contact";
---

<footer class="border-t border-stone-200 bg-gradient-to-b from-white to-stone-50 pt-10 pb-8 md:pt-14">
  <div class="mx-auto w-[min(1160px,92%)]">
    <div class="grid gap-4 border-b border-stone-200 pb-8 md:gap-6 md:pb-10 md:grid-cols-2 lg:grid-cols-3">
      <section class="rounded-2xl border border-stone-200 bg-white/90 p-5 shadow-[0_8px_24px_rgba(15,23,42,0.05)] md:border-0 md:bg-transparent md:p-0 md:shadow-none">
        <h3 class="font-display text-2xl font-bold text-slate-900">Maa's Magic</h3>
        <p class="mt-3 text-sm leading-6 text-slate-600">Homemade Kerala achar in small batches with trusted quality and direct WhatsApp ordering.</p>
        <div class="mt-4 flex flex-wrap gap-2">
          <a href={`tel:${companyContact.phoneE164}`} class="inline-flex items-center gap-2 rounded-full border border-stone-300 bg-white px-3 py-1.5 text-xs font-bold text-slate-700 hover:bg-stone-100">
            <i class="fa-solid fa-phone"></i>
            Call
          </a>
          <a href={`https://wa.me/${companyContact.whatsappNumber}`} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-xs font-bold text-emerald-700 hover:bg-emerald-100">
            <i class="fa-brands fa-whatsapp"></i>
            WhatsApp
          </a>
        </div>
      </section>

      <section class="rounded-2xl border border-stone-200 bg-white/90 p-5 shadow-[0_8px_24px_rgba(15,23,42,0.05)] md:border-0 md:bg-transparent md:p-0 md:shadow-none">
        <h4 class="text-sm font-extrabold uppercase tracking-wide text-slate-700">Quick Links</h4>
        <ul class="mt-3 grid grid-cols-2 gap-2 text-sm font-semibold text-slate-600 md:grid-cols-1 md:gap-2 md:space-y-0">
          <li><a href={`${import.meta.env.BASE_URL}#menu`} class="inline-flex w-full rounded-lg px-2 py-1.5 hover:bg-stone-100 hover:text-slate-900">Products</a></li>
          <li><a href={`${import.meta.env.BASE_URL}#about`} class="inline-flex w-full rounded-lg px-2 py-1.5 hover:bg-stone-100 hover:text-slate-900">About Us</a></li>
          <li><a href={`${import.meta.env.BASE_URL}#order`} class="inline-flex w-full rounded-lg px-2 py-1.5 hover:bg-stone-100 hover:text-slate-900">How to Order</a></li>
          <li><a href={`${import.meta.env.BASE_URL}#contact`} class="inline-flex w-full rounded-lg px-2 py-1.5 hover:bg-stone-100 hover:text-slate-900">Contact</a></li>
        </ul>
      </section>

      <section class="rounded-2xl border border-stone-200 bg-white/90 p-5 shadow-[0_8px_24px_rgba(15,23,42,0.05)] md:border-0 md:bg-transparent md:p-0 md:shadow-none">
        <h4 class="text-sm font-extrabold uppercase tracking-wide text-slate-700">Business Hours</h4>
        <ul class="mt-3 space-y-3 text-sm font-semibold text-slate-600">
          <li class="flex items-start gap-2"><i class="fa-regular fa-clock mt-0.5 text-brand-600"></i><span>Monday - Saturday: 9:00 AM - 6:00 PM</span></li>
          <li class="flex items-start gap-2"><i class="fa-regular fa-clock mt-0.5 text-brand-600"></i><span>Sunday: 10:00 AM - 2:00 PM</span></li>
          <li class="flex items-start gap-2"><i class="fa-solid fa-box mt-0.5 text-brand-600"></i><span>For bulk orders, please provide advance notice.</span></li>
        </ul>
      </section>
    </div>

    <div class="mt-6 grid items-center gap-4 text-sm font-semibold text-slate-500 md:grid-cols-3 md:gap-6">
      <p class="text-center md:text-left">© {year} Maa's Magic. All rights reserved.</p>

      <a
        href="https://atherpulse.in"
        target="_blank"
        rel="noreferrer"
        class="mx-auto inline-flex items-center gap-2 rounded-full border border-brand-500/35 bg-brand-100 px-4 py-2 text-xs font-semibold text-brand-900 transition hover:bg-brand-500 hover:text-white"
      >
        <span class="opacity-80">Made by</span>
        <span class="font-bold">Atherpulse Technologies</span>
        <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
      </a>

      <p class="text-center md:text-right">Handmade with care in Vadakara.</p>
    </div>
  </div>
</footer>
