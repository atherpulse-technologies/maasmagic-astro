---
const year = new Date().getFullYear();
---

<footer class="border-t border-stone-200 bg-white pt-14 pb-8">
  <div class="mx-auto w-[min(1160px,92%)]">
    <div class="grid gap-8 border-b border-stone-200 pb-10 md:grid-cols-2 lg:grid-cols-4">
      <section>
        <h3 class="font-display text-2xl font-bold text-slate-900">Maa's Magic</h3>
        <p class="mt-3 text-sm leading-6 text-slate-600">Homemade Kerala achar in small batches with trusted quality and direct WhatsApp ordering.</p>
      </section>

      <section>
        <h4 class="text-sm font-extrabold uppercase tracking-wide text-slate-700">Quick Links</h4>
        <ul class="mt-3 space-y-2 text-sm font-semibold text-slate-600">
          <li><a href={`${import.meta.env.BASE_URL}#menu`} class="hover:text-slate-900">Products</a></li>
          <li><a href={`${import.meta.env.BASE_URL}#about`} class="hover:text-slate-900">About Us</a></li>
          <li><a href={`${import.meta.env.BASE_URL}#order`} class="hover:text-slate-900">How to Order</a></li>
          <li><a href={`${import.meta.env.BASE_URL}#contact`} class="hover:text-slate-900">Contact</a></li>
        </ul>
      </section>

      <section>
        <h4 class="text-sm font-extrabold uppercase tracking-wide text-slate-700">Contact</h4>
        <ul class="mt-3 space-y-2 text-sm font-semibold text-slate-600">
          <li><a href="tel:+919100000000" class="hover:text-slate-900">+91 91000 00000</a></li>
          <li><a href="mailto:orders@maasmagic.in" class="hover:text-slate-900">orders@maasmagic.in</a></li>
          <li><a href="https://wa.me/910000000000" class="hover:text-slate-900">WhatsApp Chat</a></li>
          <li><a href="https://www.instagram.com" class="hover:text-slate-900">Instagram</a></li>
        </ul>
      </section>

      <section class="rounded-2xl border border-amber-200 bg-amber-50 p-4">
        <h4 class="text-sm font-extrabold uppercase tracking-wide text-amber-900">Service Promise</h4>
        <ul class="mt-3 space-y-2 text-sm font-semibold text-amber-900">
          <li>Small-batch homemade preparation</li>
          <li>Direct support on WhatsApp</li>
          <li>Quick order confirmation flow</li>
          <li>Freshness-focused delivery handling</li>
        </ul>
      </section>
    </div>

    <div class="mt-6 grid items-center gap-3 text-sm font-semibold text-slate-500 md:grid-cols-3">
      <p class="text-center md:text-left">© {year} Maa's Magic. All rights reserved.</p>

      <a
        href="https://atherpulse.in"
        target="_blank"
        rel="noreferrer"
        class="mx-auto inline-flex items-center gap-2 rounded-full border border-brand-500/35 bg-brand-100 px-5 py-2 text-xs font-semibold text-brand-900 transition hover:bg-brand-500 hover:text-white"
      >
        <span class="opacity-80">Made by</span>
        <span class="font-bold">Atherpulse Technologies</span>
        <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
      </a>

      <p class="text-center md:text-right">Made for quick cart-to-WhatsApp checkout.</p>
    </div>
  </div>
</footer>
