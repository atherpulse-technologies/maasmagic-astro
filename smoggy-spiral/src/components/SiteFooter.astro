---
const year = new Date().getFullYear();
import { companyContact } from "../config/contact";
---

<style>
  footer {
    background-color: #f8f9fa;
    padding: 2rem 1rem;
    font-family: 'Inter', sans-serif;
  }

  footer h3, footer h4 {
    color: #343a40;
    margin-bottom: 1rem;
  }

  footer p, footer ul li {
    color: #6c757d;
    line-height: 1.6;
  }

  footer ul {
    list-style: none;
    padding: 0;
  }

  footer ul li {
    margin-bottom: 0.5rem;
  }

  footer ul li a {
    color: inherit; /* Reverted to original style */
    text-decoration: none;
    transition: color 0.3s;
  }

  footer ul li a:hover {
    color: inherit; /* Reverted to original style */
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    justify-content: space-between;
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    border-top: 1px solid #dee2e6;
    padding-top: 1rem;
    margin-top: 1rem;
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>

<footer class="border-t border-stone-200 bg-white pt-14 pb-8">
  <div class="mx-auto w-[min(1160px,92%)]">
    <div class="grid gap-8 border-b border-stone-200 pb-10 md:grid-cols-2 lg:grid-cols-3">
      <section>
        <h3 class="font-display text-2xl font-bold text-slate-900">Maa's Magic</h3>
        <p class="mt-3 text-sm leading-6 text-slate-600">Homemade Kerala achar in small batches with trusted quality and direct WhatsApp ordering.</p>
      </section>

      <section>
        <h4 class="text-sm font-extrabold uppercase tracking-wide text-slate-700">Quick Links</h4>
        <ul class="mt-3 space-y-2 text-sm font-semibold text-slate-600">
          <li><a href={`${import.meta.env.BASE_URL}#menu`} class="hover:text-slate-900">Products</a></li>
          <li><a href={`${import.meta.env.BASE_URL}#about`} class="hover:text-slate-900">About Us</a></li>
          <li><a href={`${import.meta.env.BASE_URL}#order`} class="hover:text-slate-900">How to Order</a></li>
          <li><a href={`${import.meta.env.BASE_URL}#contact`} class="hover:text-slate-900">Contact</a></li>
        </ul>
      </section>

      <section>
        <h4 class="text-sm font-extrabold uppercase tracking-wide text-slate-700">Business Hours</h4>
        <ul class="mt-3 space-y-4 text-sm font-semibold text-slate-600">
          <li>Monday - Saturday: 9:00 AM - 6:00 PM</li>
          <li>Sunday: 10:00 AM - 2:00 PM</li>
                    <li>For bulk orders, please provide advance notice.</li>

        </ul>
      </section>

  
    </div>

    <div class="mt-6 grid items-center gap-6 text-sm font-semibold text-slate-500 md:grid-cols-3">
      <p class="text-center md:text-left">© {year} Maa's Magic. All rights reserved.</p>

      <a
        href="https://atherpulse.in"
        target="_blank"
        rel="noreferrer"
        class="mx-auto inline-flex items-center gap-2 rounded-full border border-brand-500/35 bg-brand-100 px-5 py-2 text-xs font-semibold text-brand-900 transition hover:bg-brand-500 hover:text-white"
      >
        <span class="opacity-80">Made by</span>
        <span class="font-bold">Atherpulse Technologies</span>
        <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
      </a>

      <p class="text-center md:text-right">Handmade with care in Vadakara.</p>
    </div>
  </div>
</footer>
