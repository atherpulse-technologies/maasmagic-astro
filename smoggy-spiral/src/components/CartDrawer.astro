<div class="pointer-events-none fixed inset-0 z-50 opacity-0 transition-opacity duration-200" data-cart-overlay></div>

<aside class="pointer-events-none fixed right-0 top-0 z-50 flex h-full w-full max-w-md translate-x-full flex-col border-l border-stone-200 bg-white shadow-soft transition-transform duration-300" data-cart-drawer>
  <header class="flex items-center justify-between border-b border-stone-200 px-5 py-4">
    <h2 class="font-display text-2xl font-bold text-slate-900">Your Cart</h2>
    <button class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-stone-300 text-slate-600 hover:bg-stone-100" data-close-cart aria-label="Close cart">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </header>

  <div class="flex-1 overflow-y-auto px-5 py-4" data-cart-items>
    <p class="text-sm text-slate-500">Your cart is empty. Add products to get started.</p>
  </div>

  <footer class="border-t border-stone-200 px-5 py-4">
    <div class="mb-3 flex items-center justify-between text-sm text-slate-600">
      <span>Total</span>
      <strong class="text-base text-slate-900" data-cart-total>₹0</strong>
    </div>

    <div class="mb-4 rounded-xl border border-stone-200 bg-stone-50 p-3">
      <p class="text-xs font-bold uppercase tracking-wide text-slate-600">Delivery Details</p>
      <div class="mt-3 space-y-2">
        <label class="block">
          <span class="mb-1 block text-xs font-semibold text-slate-600">Name</span>
          <input type="text" maxlength="40" placeholder="Your name" class="w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-sm text-slate-800 outline-none ring-brand-300 focus:ring" data-customer-name />
        </label>
        <label class="block">
          <span class="mb-1 block text-xs font-semibold text-slate-600">Address</span>
          <textarea rows="2" maxlength="140" placeholder="Short address" class="w-full resize-none rounded-lg border border-stone-300 bg-white px-3 py-2 text-sm text-slate-800 outline-none ring-brand-300 focus:ring" data-customer-address></textarea>
        </label>
        <label class="block">
          <span class="mb-1 block text-xs font-semibold text-slate-600">Phone</span>
          <input type="tel" maxlength="15" placeholder="Phone number" class="w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-sm text-slate-800 outline-none ring-brand-300 focus:ring" data-customer-phone />
        </label>
      </div>
      <p class="mt-2 text-[11px] text-slate-500">Saved on this device for faster checkout. You can edit anytime.</p>
      <div class="mt-2 rounded-lg border border-stone-200 bg-white px-2.5 py-2 text-[11px] text-slate-600" data-customer-preview></div>
    </div>

    <button class="flex w-full items-center justify-center gap-2 rounded-xl bg-brand-500 px-4 py-3 text-sm font-bold text-white hover:bg-brand-600" data-whatsapp-order>
      <i class="fa-brands fa-whatsapp"></i>
      Order on WhatsApp
    </button>
    <p class="mt-2 text-xs text-slate-500">You can edit quantities before sending.</p>
  </footer>
</aside>

<section class="pointer-events-none fixed inset-0 z-[70] opacity-0 transition-opacity duration-200" data-order-loading-overlay>
  <div class="absolute inset-0 bg-slate-950/75"></div>
  <div class="relative flex h-full w-full items-center justify-center px-4 text-center">
    <div class="w-full max-w-xl">
      <span class="order-spinner mx-auto inline-block h-14 w-14 rounded-full border-4 border-white/30"></span>
      <h3 class="mt-6 font-display text-4xl font-bold text-white">Preparing your WhatsApp order...</h3>
      <p class="mt-3 text-base text-white/80">Please wait while we package your cart details.</p>
    </div>
  </div>
</section>

<section class="pointer-events-none fixed inset-0 z-[70] opacity-0 transition-opacity duration-200" data-order-confirm-overlay>
  <div class="absolute inset-0 bg-slate-950/80"></div>
  <div class="relative flex h-full w-full items-center justify-center px-4 py-6">
    <div class="w-full max-w-2xl rounded-3xl border border-white/20 bg-white p-6 shadow-soft sm:p-8">
      <h3 class="font-display text-3xl font-bold text-slate-900 sm:text-4xl">Did you place the WhatsApp order?</h3>
      <p class="mt-2 text-sm text-slate-600 sm:text-base">If your order was sent on WhatsApp, confirm below and we will clear your cart.</p>
      <div class="mt-5 hidden rounded-xl border border-stone-200 bg-stone-50 p-4" data-order-desktop-help>
        <p class="text-sm font-semibold text-slate-800">Desktop fallback:</p>
        <p class="mt-1 text-sm text-slate-600">If WhatsApp app did not open, use WhatsApp Web or copy the message and paste it manually.</p>
        <div class="mt-4 grid gap-2 sm:grid-cols-2">
          <button class="inline-flex items-center justify-center rounded-lg border border-stone-300 bg-white px-3 py-2.5 text-sm font-bold text-slate-700 hover:bg-stone-100" data-open-whatsapp-web>
            Open WhatsApp Web
          </button>
          <button class="inline-flex items-center justify-center rounded-lg border border-stone-300 bg-white px-3 py-2.5 text-sm font-bold text-slate-700 hover:bg-stone-100" data-copy-order-text>
            Copy Order Text
          </button>
        </div>
        <p class="mt-2 text-xs text-emerald-700" data-copy-status></p>
      </div>
      <div class="mt-6 grid gap-2 sm:grid-cols-2">
        <button class="inline-flex items-center justify-center rounded-xl bg-emerald-600 px-4 py-3 text-sm font-bold text-white hover:bg-emerald-700" data-order-confirm-yes>
          Yes, order placed
        </button>
        <button class="inline-flex items-center justify-center rounded-xl border border-stone-300 bg-white px-4 py-3 text-sm font-bold text-slate-700 hover:bg-stone-50" data-order-confirm-no>
          Not yet
        </button>
      </div>
    </div>
  </div>
</section>
