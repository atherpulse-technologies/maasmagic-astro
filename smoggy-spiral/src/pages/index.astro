---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import CartDrawer from "../components/CartDrawer.astro";
import ProductCard from "../components/ProductCard.astro";
import { nonVegProducts, vegProducts } from "../data/products";
---

<BaseLayout
  title="Maa's Magic | Homemade Kerala Pickles"
  description="Browse homemade Kerala achar, add products to cart, and send orders directly through WhatsApp."
  canonicalPath="/"
>
  <SiteHeader currentPath="/" />
  <CartDrawer />

  <main id="main-content">
    <section class="animate-in border-b border-stone-200 bg-gradient-to-b from-white to-brand-50/40" data-animate>
      <div class="mx-auto grid w-[min(1160px,92%)] gap-10 py-16 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:py-20">
        <div>
          <span class="mb-5 inline-flex items-center gap-2 rounded-full border border-amber-200 bg-amber-50 px-4 py-1.5 text-xs font-extrabold uppercase tracking-wide text-amber-800">
            <i class="fa-solid fa-star"></i>
            Homemade Pickles from Vadakara
          </span>

          <h1 class="max-w-[18ch] font-display text-4xl font-bold leading-tight text-slate-900 sm:text-5xl lg:text-6xl">
            Trusted Kerala achar for your everyday meals.
          </h1>

          <p class="mt-5 max-w-[58ch] text-lg text-slate-600">
            Freshly prepared in small batches with quality ingredients and family recipes.
            Build your cart and place your order instantly through WhatsApp.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <button class="inline-flex items-center gap-2 rounded-xl bg-slate-900 px-6 py-3 text-sm font-bold text-white transition hover:bg-slate-800" data-open-cart>
              <i class="fa-solid fa-cart-shopping"></i>
              Open Cart
              <span class="inline-grid h-5 min-w-5 place-items-center rounded-full bg-white/20 px-1 text-[11px]" data-cart-count>0</span>
            </button>
            <a href="#menu" class="inline-flex items-center gap-2 rounded-xl border border-stone-300 bg-white px-6 py-3 text-sm font-bold text-slate-700 transition hover:bg-stone-50">
              <i class="fa-solid fa-box-open"></i>
              View Products
            </a>
          </div>

          <p class="mt-4 text-sm font-semibold text-slate-500">Cart to WhatsApp checkout. No payment gateway needed.</p>
        </div>

        <div class="relative rounded-2xl border border-amber-200 bg-white p-4 shadow-soft sm:p-6">
          <span class="absolute left-5 top-5 rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-bold text-amber-800">
            Hero Product Mockup
          </span>
          <img
            src={`${import.meta.env.BASE_URL}productmockup.jpg`}
            alt="Large product mockup"
            class="h-[320px] w-full rounded-xl border border-stone-200 bg-white object-contain p-2 sm:h-[380px]"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <section class="animate-in border-b border-stone-200 bg-brand-50/45" data-animate>
      <div class="mx-auto grid w-[min(1160px,92%)] gap-4 py-7 sm:grid-cols-2 lg:grid-cols-4">
        <div class="px-2 py-1">
          <p class="flex items-center gap-2 text-sm font-semibold text-slate-700"><i class="fa-solid fa-house text-brand-600"></i> Homemade in small batches</p>
        </div>
        <div class="px-2 py-1">
          <p class="flex items-center gap-2 text-sm font-semibold text-slate-700"><i class="fa-solid fa-bowl-food text-brand-600"></i> Veg + Non-veg varieties</p>
        </div>
        <div class="px-2 py-1">
          <p class="flex items-center gap-2 text-sm font-semibold text-slate-700"><i class="fa-solid fa-tags text-brand-600"></i> Uniform pricing ₹100 | 100g</p>
        </div>
        <div class="px-2 py-1">
          <p class="flex items-center gap-2 text-sm font-semibold text-slate-700"><i class="fa-brands fa-whatsapp text-brand-600"></i> Direct WhatsApp support</p>
        </div>
      </div>
    </section>

    <section id="menu" class="animate-in py-20" data-animate>
      <div class="mx-auto w-[min(1160px,92%)]">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="font-display text-4xl font-bold text-slate-900">Our Product Range</h2>
          <p class="mt-3 text-lg text-slate-600">
            Browse products, open individual product pages, add quantities, and complete ordering through WhatsApp.
          </p>
        </div>

        <div class="mt-12">
          <h3 class="mb-5 font-display text-2xl font-bold text-slate-900">Vegetarian Delights</h3>
          <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {vegProducts.map((product) => <ProductCard product={product} />)}
          </div>
        </div>

        <div class="mt-14">
          <h3 class="mb-5 font-display text-2xl font-bold text-slate-900">Non-Vegetarian Specialties</h3>
          <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {nonVegProducts.map((product) => <ProductCard product={product} />)}
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="animate-in border-y border-stone-200 bg-white py-20" data-animate>
      <div class="mx-auto grid w-[min(1160px,92%)] gap-6 lg:grid-cols-2">
        <article class="rounded-2xl border border-stone-200 bg-stone-50 p-6">
          <h3 class="font-display text-3xl font-bold text-slate-900">About Maa's Magic</h3>
          <p class="mt-3 text-slate-600">
            We focus on consistency, clean ingredients, and authentic taste so every jar feels like homemade food from a trusted kitchen.
          </p>
        </article>
        <article class="rounded-2xl border border-stone-200 bg-stone-50 p-6">
          <h3 class="font-display text-3xl font-bold text-slate-900">Why this ordering model works</h3>
          <p class="mt-3 text-slate-600">
            Customers add to cart online, then send a confirmed WhatsApp order in one tap. You get complete order details with zero checkout friction.
          </p>
        </article>
      </div>
    </section>

    <section id="order" class="animate-in border-b border-stone-200 bg-white py-20" data-animate>
      <div class="mx-auto w-[min(1160px,92%)]">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="font-display text-4xl font-bold text-slate-900">How to Order</h2>
          <p class="mt-3 text-lg text-slate-600">Simple three-step WhatsApp checkout flow.</p>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-3">
          <article class="rounded-xl border border-stone-200 bg-stone-50 p-5">
            <span class="inline-grid h-8 w-8 place-items-center rounded-full bg-slate-900 text-sm font-bold text-white">1</span>
            <h4 class="mt-3 text-lg font-bold">Add to cart</h4>
            <p class="mt-2 text-sm text-slate-600">Choose products from list or individual product pages.</p>
          </article>
          <article class="rounded-xl border border-stone-200 bg-stone-50 p-5">
            <span class="inline-grid h-8 w-8 place-items-center rounded-full bg-slate-900 text-sm font-bold text-white">2</span>
            <h4 class="mt-3 text-lg font-bold">Review quantity and total</h4>
            <p class="mt-2 text-sm text-slate-600">Update quantities from cart drawer and verify total amount.</p>
          </article>
          <article class="rounded-xl border border-stone-200 bg-stone-50 p-5">
            <span class="inline-grid h-8 w-8 place-items-center rounded-full bg-slate-900 text-sm font-bold text-white">3</span>
            <h4 class="mt-3 text-lg font-bold">Send on WhatsApp</h4>
            <p class="mt-2 text-sm text-slate-600">Tap order button to open WhatsApp with prefilled message.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="contact" class="animate-in border-b border-stone-200 bg-stone-50 py-20" data-animate>
      <div class="mx-auto w-[min(1160px,92%)]">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="font-display text-4xl font-bold text-slate-900">Contact Us</h2>
          <p class="mt-3 text-lg text-slate-600">Reach us directly for orders, delivery support, and bulk enquiries.</p>
        </div>

        <div class="mt-10 grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
          <article class="rounded-2xl border border-stone-200 bg-white p-6 shadow-soft">
            <h3 class="font-display text-2xl font-bold text-slate-900">Maa's Magic Kitchen</h3>
            <div class="mt-5 space-y-4 text-sm text-slate-700">
              <p class="flex items-start gap-3">
                <i class="fa-solid fa-phone mt-0.5 text-brand-600"></i>
                <span>
                  <span class="block text-xs font-bold uppercase tracking-wide text-slate-500">Phone</span>
                  <a href="tel:+919100000000" class="font-semibold hover:text-slate-900">+91 91000 00000</a>
                </span>
              </p>
              <p class="flex items-start gap-3">
                <i class="fa-solid fa-envelope mt-0.5 text-brand-600"></i>
                <span>
                  <span class="block text-xs font-bold uppercase tracking-wide text-slate-500">Email</span>
                  <a href="mailto:orders@maasmagic.in" class="font-semibold hover:text-slate-900">orders@maasmagic.in</a>
                </span>
              </p>
              <p class="flex items-start gap-3">
                <i class="fa-solid fa-location-dot mt-0.5 text-brand-600"></i>
                <span>
                  <span class="block text-xs font-bold uppercase tracking-wide text-slate-500">Address</span>
                  Near Vadakara Town, Kozhikode District, Kerala 673101
                </span>
              </p>
              <p class="flex items-start gap-3">
                <i class="fa-regular fa-clock mt-0.5 text-brand-600"></i>
                <span>
                  <span class="block text-xs font-bold uppercase tracking-wide text-slate-500">Working Hours</span>
                  Mon - Sat: 9:00 AM to 7:00 PM
                </span>
              </p>
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
              <a href="tel:+919100000000" class="inline-flex items-center gap-2 rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-bold text-white hover:bg-slate-800">
                <i class="fa-solid fa-phone"></i>
                Call Now
              </a>
              <a href="mailto:orders@maasmagic.in" class="inline-flex items-center gap-2 rounded-xl border border-stone-300 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-stone-100">
                <i class="fa-solid fa-paper-plane"></i>
                Send Email
              </a>
            </div>
          </article>

          <article class="overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-soft">
            <iframe
              title="Maa's Magic location map"
              src="https://www.google.com/maps?q=Vadakara%2C%20Kerala&z=13&output=embed"
              class="h-[380px] w-full border-0"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </article>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
