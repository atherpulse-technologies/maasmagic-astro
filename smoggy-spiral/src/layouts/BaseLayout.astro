---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
}

const {
  title = "Maa's Magic | Homemade Pickles",
  description = "Authentic homemade Kerala achar from Vadakara. Order quickly through WhatsApp.",
  canonicalPath = "/",
  image = "/maasmagic_logo.png",
} = Astro.props as Props;

const siteUrl = "https://maasmagic.example";
const canonical = `${siteUrl}${canonicalPath}`;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Maa's Magic, Kerala pickle, homemade achar, Vadakara, pickle solution" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Maa's Magic" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Maa's Magic" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      referrerpolicy="no-referrer"
    />

    <title>{title}</title>
    <script type="application/ld+json" is:inline>
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        name: "Maa's Magic",
        description,
        url: siteUrl,
        logo: `${siteUrl}/maasmagic_logo.png`,
      })}
    </script>
  </head>
  <body class="bg-stone-50 text-slate-800 antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-slate-900 focus:px-3 focus:py-2 focus:text-sm focus:text-white">Skip to content</a>
    <slot />
    <script is:inline type="module" src={`${import.meta.env.BASE_URL}js/site-ui.js`}></script>
  </body>
</html>
